# Copy to .env and fill in real values. .env is gitignored.

# --- Neo4j ---------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# --- Datadog -------------------------------------------------------------
# https://docs.datadoghq.com/account_management/api-app-keys/
DD_API_KEY=
DD_APP_KEY=
DD_SITE=datadoghq.com
# Lookback window for trace ingestion, in hours.
DD_TRACE_LOOKBACK_HOURS=720

# --- GitHub --------------------------------------------------------------
# Personal access token for github.com (PAT with `repo` scope for private repos).
GITHUB_TOKEN=
GITHUB_API_URL=https://api.github.com
# Comma-separated list of "owner/repo" to ingest (optional; CLI is preferred).
GITHUB_REPOS=
# Where shallow clones live and where the SHA cache is kept.
GITHUB_CLONES_DIR=./out/github_repos
GITHUB_STORE_PATH=./out/github.db
GITHUB_DEFAULT_BRANCH=

# Per-host PATs for other GitHub deployments (e.g. GitHub Enterprise).
# Convention: GITHUB_TOKEN_<HOST>, where <HOST> uppercases the hostname and
# replaces `.` and `-` with `_`. Examples:
#   GITHUB_TOKEN_GHE_ACME_COM=ghp_xxx     # for ghe.acme.com
#   GITHUB_TOKEN_GIT_INTERNAL=ghp_yyy     # for git.internal
# Validate with: sg-ingest github auth check --host ghe.acme.com

# --- Test parser ---------------------------------------------------------
# Local filesystem path containing checked-out repos to scan.
TESTPARSER_ROOT=./examples/test_project

# --- Oracle stack --------------------------------------------------------
# Comma-separated list of Oracle Forms applications that don't appear as
# `.fmb`/`.fmx` files in the source tree but should still surface as
# Service nodes in the graph. Each name becomes a separate Service.
ORACLE_FORMS_APPS=

# --- LLM fallback grammar ------------------------------------------------
# When set, files in languages without a native grammar (.go, .rb, .ts, ...)
# are extracted via Anthropic's API. Unset or empty = those files are
# skipped silently. See docs/LLM_PROMPTS.md for the queries used.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Override the default extension list the LLM grammar claims (CSV).
# Empty = use the stock list (.go, .rb, .ts, .kt, .rs, ... — see
# core/languages/grammar_registry.py:_DEFAULT_LLM_FALLBACK_SUFFIXES).
# Set to a narrower list to scope LLM cost (e.g. LLM_FALLBACK_SUFFIXES=go,rb).
LLM_FALLBACK_SUFFIXES=

# --- Logging -------------------------------------------------------------
LOG_LEVEL=INFO
